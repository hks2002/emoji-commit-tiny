{
  "name": "emoji-commit-tiny",
  "displayName": "Emoji Commit Tiny",
  "description": "Add emoji to git commit message",
  "publisher": "MerBleueAviation",
  "repository": {
    "type": "git",
    "url": "https://github.com/hks2002/emoji-commit-tiny.git"
  },
  "license": "MIT",
  "version": "0.1.1",
  "scripts": {
    "compile": "cspell . && node esbuild.config.js",
    "watch": "node esbuild.config.js --watch",
    "lint": "eslint src --ext js",
    "spell-check": "cspell .",
    "pretest": "yarn run compile && yarn run lint",
    "test": "node ./src/test/runTest.js",
    "vscode:prepublish": "yarn run compile",
    "publish": "vsce publish --yarn --skip-duplicate",
    "package": "vsce package --yarn"
  },
  "dependencies": {},
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@vscode/test-electron": "^2.2.0",
    "@vscode/vsce": "^3.7.1",
    "cspell": "^9.6.0",
    "esbuild": "^0.27.2",
    "eslint": "^9.39.2",
    "fast-glob": "3.3.3",
    "globals": "^17.0.0",
    "mocha": "^10.1.0"
  },
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "emoji",
    "commit",
    "git"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "l10n": "./l10n",
  "contributes": {
    "commands": [
      {
        "command": "emoji-commit-tiny.emojiCommit",
        "title": "git emoji commit",
        "icon": {
          "dark": "images/icon.svg",
          "light": "images/icon_light.svg"
        }
      }
    ],
    "menus": {
      "scm/title": [
        {
          "when": "scmProvider == git",
          "command": "emoji-commit-tiny.emojiCommit",
          "group": "navigation"
        }
      ]
    },
    "configuration": [
      {
        "title": "Emoji Commit Tiny",
        "properties": {
          "emoji-commit-tiny.position": {
            "order": 1,
            "type": "string",
            "default": "suffix",
            "enum": [
              "prefix",
              "middle",
              "suffix",
              "none"
            ],
            "description": "%emoji-commit-tiny.emojiPosition%"
          },
          "emoji-commit-tiny.emojis": {
            "order": 3,
            "type": "object",
            "default": {
              "feat": "✨",
              "fix": "🐛",
              "docs": "📚",
              "style": "🎨",
              "refactor": "♻️",
              "perf": "🚀",
              "test": "🧪",
              "build": "🛠️",
              "ci": "⚙️",
              "chore": "🔧",
              "revert": "🔙"
            },
            "properties": {
              "feat": {
                "type": "string",
                "default": "✨"
              },
              "fix": {
                "type": "string",
                "default": "🐛"
              },
              "docs": {
                "type": "string",
                "default": "📚"
              },
              "style": {
                "type": "string",
                "default": "🎨"
              },
              "refactor": {
                "type": "string",
                "default": "♻️"
              },
              "perf": {
                "type": "string",
                "default": "🚀"
              },
              "test": {
                "type": "string",
                "default": "🧪"
              },
              "build": {
                "type": "string",
                "default": "🛠️"
              },
              "ci": {
                "type": "string",
                "default": "⚙️"
              },
              "chore": {
                "type": "string",
                "default": "🔧"
              },
              "revert": {
                "type": "string",
                "default": "🔙"
              }
            },
            "additionalProperties": false,
            "markdownDescription": "%emoji-commit-tiny.emojis%"
          },
          "emoji-commit-tiny.additionalType": {
            "order": 4,
            "type": "array",
            "default": [
              {
                "type": "init",
                "emoji": "🎉",
                "name": "初始化",
                "description": "初次提交/初始化项目"
              },
              {
                "type": "release",
                "emoji": "🏷️",
                "name": "发布",
                "description": "发布版本"
              },
              {
                "type": "publish",
                "emoji": "🎉",
                "name": "新版本",
                "description": "发布新版本"
              },
              {
                "type": "tag",
                "emoji": "🏷️",
                "name": "标签",
                "description": "发布版本/添加标签"
              }
            ],
            "additionalProperties": true,
            "markdownDescription": "%emoji-commit-tiny.additionalTypes%"
          }
        }
      }
    ]
  }
}