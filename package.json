{
  "name": "emoji-commit-tiny",
  "displayName": "Emoji Commit Tiny",
  "version": "0.3.1",
  "description": "Add emoji to git commit message",
  "categories": [
    "Other"
  ],
  "keywords": [
    "commit",
    "emoji",
    "git"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hks2002/emoji-commit-tiny.git"
  },
  "publisher": "MerBleueAviation",
  "type": "module",
  "main": "./dist/extension.js",
  "scripts": {
    "lint": "oxlint",
    "fmt": "oxfmt --write",
    "cspell": "cspell .",
    "build": "node esbuild.js",
    "dev": "node esbuild.js --watch",
    "pretest": "pnpm run lint && pnpm run build",
    "test": "node ./test/runTest.js",
    "vscode:prepublish": "pnpm run build",
    "publish": "vsce publish --skip-duplicate --no-dependencies",
    "package": "vsce package --no-dependencies"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/vscode": "^1.100.0",
    "@vscode/l10n-dev": "^0.0.18",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.9.2",
    "cspell": "^9.6.0",
    "esbuild": "^0.28.1",
    "fast-glob": "3.3.3",
    "mocha": "^10.1.0",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0"
  },
  "engines": {
    "vscode": "^1.100.0"
  },
  "icon": "images/icon.png",
  "l10n": "./l10n",
  "activationEvents": [],
  "contributes": {
    "commands": [
      {
        "command": "emoji-commit-tiny.emojiCommit",
        "title": "git emoji commit",
        "icon": {
          "dark": "images/icon.svg",
          "light": "images/icon_light.svg"
        }
      }
    ],
    "menus": {
      "scm/title": [
        {
          "when": "scmProvider == git",
          "command": "emoji-commit-tiny.emojiCommit",
          "group": "navigation"
        }
      ]
    },
    "configuration": [
      {
        "title": "Emoji Commit Tiny",
        "properties": {
          "emoji-commit-tiny.position": {
            "order": 1,
            "type": "string",
            "default": "end",
            "enum": [
              "prefix",
              "middle",
              "suffix",
              "end",
              "none"
            ],
            "description": "%emoji-commit-tiny.emojiPosition%"
          },
          "emoji-commit-tiny.emojis": {
            "order": 3,
            "type": "object",
            "default": {
              "feat": "✨",
              "fix": "🐛",
              "docs": "📚",
              "style": "🎨",
              "refactor": "♻️",
              "perf": "🚀",
              "test": "🧪",
              "build": "🛠️",
              "ci": "⚙️",
              "chore": "🧹",
              "revert": "🔙"
            },
            "properties": {
              "feat": {
                "type": "string",
                "default": "✨"
              },
              "fix": {
                "type": "string",
                "default": "🐛"
              },
              "docs": {
                "type": "string",
                "default": "📚"
              },
              "style": {
                "type": "string",
                "default": "🎨"
              },
              "refactor": {
                "type": "string",
                "default": "♻️"
              },
              "perf": {
                "type": "string",
                "default": "🚀"
              },
              "test": {
                "type": "string",
                "default": "🧪"
              },
              "build": {
                "type": "string",
                "default": "🛠️"
              },
              "ci": {
                "type": "string",
                "default": "⚙️"
              },
              "chore": {
                "type": "string",
                "default": "🧹"
              },
              "revert": {
                "type": "string",
                "default": "🔙"
              }
            },
            "additionalProperties": false,
            "markdownDescription": "%emoji-commit-tiny.emojis%"
          },
          "emoji-commit-tiny.additionalType": {
            "order": 4,
            "type": "array",
            "default": [
              {
                "type": "init",
                "emoji": "🎉",
                "name": "初始化",
                "description": "初次提交/初始化项目"
              }
            ],
            "additionalProperties": true,
            "markdownDescription": "%emoji-commit-tiny.additionalTypes%"
          }
        }
      }
    ]
  }
}